{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "!node_modules",
      "!dist",
      "!build",
      "!**/dist",
      "!**/build",
      "!assets/pdf.js",
      "!.pnpm-store"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["assets/main.mjs"],
      "linter": {
        "rules": {
          "complexity": {
            "noVoid": "off"
          },
          "style": {
            "useDefaultSwitchClause": "off"
          }
        }
      }
    }
  ],
  "extends": ["ultracite/core"]
}
