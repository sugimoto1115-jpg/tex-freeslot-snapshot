{
  "name": "texcloud-plus",
  "displayName": "TeX Cloud Plus",
  "description": "Overleaf-like helpers for TeX in code-server",
  "version": "0.0.6",
  "publisher": "tomoyuki",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:texcloud.buildCurrent",
    "onCommand:texcloud.watchCurrent",
    "onCommand:texcloud.stopWatch",
    "onCommand:texcloud.openPdf",
    "onView:texcloud.sections"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "texcloud.buildCurrent",
        "title": "TeX: Build Current"
      },
      {
        "command": "texcloud.watchCurrent",
        "title": "TeX: Watch Current"
      },
      {
        "command": "texcloud.stopWatch",
        "title": "TeX: Stop Watch"
      },
      {
        "command": "texcloud.openPdf",
        "title": "TeX: Open PDF"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "texcloud.buildCurrent",
          "when": "resourceExtname == .tex",
          "group": "navigation@1"
        },
        {
          "command": "texcloud.openPdf",
          "when": "resourceExtname == .tex",
          "group": "navigation@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "texcloud",
          "title": "TeX",
          "icon": "media/tex.svg"
        }
      ]
    },
    "views": {
      "texcloud": [
        {
          "id": "texcloud.sections",
          "name": "Sections / Tags"
        }
      ]
    }
  }
}
