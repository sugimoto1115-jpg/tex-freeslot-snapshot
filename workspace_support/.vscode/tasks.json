{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TeX: Build current file",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "cd \"${fileDirname}\" && latexmk -lualatex \"${fileBasename}\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": []
    },
    {
      "label": "TeX: Watch current file",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "cd \"${fileDirname}\" && latexmk -pvc -view=none -lualatex \"${fileBasename}\""
      ],
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}